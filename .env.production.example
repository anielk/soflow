PROJECT_NAME=creator-platform
FRONTEND_PORT=3000
BACKEND_PORT=4000
POSTGRES_PORT=5432
REDIS_PORT=6379

POSTGRES_DB=creator_platform
POSTGRES_USER=creator_admin
POSTGRES_PASSWORD=replace_with_secure_password
DATABASE_URL=postgresql://creator_admin:replace_with_secure_password@postgres:5432/creator_platform?schema=public

REDIS_URL=redis://redis:6379
NEXT_PUBLIC_API_URL=https://api.example.com
NODE_ENV=production

MEDIA_STORAGE_DRIVER=local
MEDIA_STORAGE_PATH=/data/media
MEDIA_MAX_FILE_SIZE_MB=2048
