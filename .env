# Global project variables (development defaults)
PROJECT_NAME=creator-platform

# App ports
FRONTEND_PORT=3000
BACKEND_PORT=4000
POSTGRES_PORT=5432
REDIS_PORT=6379

# Database
POSTGRES_DB=creator_platform
POSTGRES_USER=creator_admin
POSTGRES_PASSWORD=creator_password
DATABASE_URL=postgresql://creator_admin:creator_password@postgres:5432/creator_platform?schema=public

# Redis
REDIS_URL=redis://redis:6379

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Backend
NODE_ENV=development
