NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://creator_admin:creator_password@localhost:5432/creator_platform?schema=public
REDIS_URL=redis://localhost:6379

# Media storage — "local" is the only implemented driver today; the app is
# structured so minio/s3/azure/gcs can be added as new StorageProvider
# implementations without touching call sites.
MEDIA_STORAGE_DRIVER=local
MEDIA_STORAGE_PATH=/data/media
MEDIA_MAX_FILE_SIZE_MB=2048
